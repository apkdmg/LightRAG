# .env template for docker-compose-no-gpu.yml
#
# A no-GPU LightRAG deployment with bundled local databases (Postgres+pgvector
# and Neo4j) and cloud LLM / embedding / reranker.
#
# Usage:
#   cp env.docker-compose-no-gpu .env
#   # edit .env — at minimum set TOKEN_SECRET, POSTGRES_PASSWORD, NEO4J_PASSWORD,
#   # and your LLM / embedding / reranker API keys.

###########################
### Core
###########################

# Signs every JWT (including SSO-issued tokens). MUST be set to 32+ random chars.
TOKEN_SECRET=replace-with-a-random-32-char-string

# Server bind inside the container. The host-side port is mapped by Compose.
HOST=0.0.0.0
PORT=9621

# Working directories inside the container (already match the Compose mounts).
WORKING_DIR=/app/data/rag_storage
INPUT_DIR=/app/data/inputs
PROMPT_DIR=/app/data/prompts

###########################
### Storage backends
###########################

# Vectors, KV, and document status all live in Postgres (pgvector).
# Graph lives in Neo4j.
LIGHTRAG_KV_STORAGE=PGKVStorage
LIGHTRAG_VECTOR_STORAGE=PGVectorStorage
LIGHTRAG_GRAPH_STORAGE=Neo4JStorage
LIGHTRAG_DOC_STATUS_STORAGE=PGDocStatusStorage

###########################
### PostgreSQL (bundled)
###########################

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=rag
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DATABASE=lightrag

# Where the bundled Postgres publishes its port on the host (for DBA access).
# Defaults to 127.0.0.1:5432. Override to expose on the admin network — e.g.
# the host's admin-network IP, or 0.0.0.0 for all interfaces (firewall it).
# POSTGRES_HOST_BIND=127.0.0.1
# POSTGRES_HOST_PORT=5432

###########################
### Neo4j (bundled)
###########################

NEO4J_URI=neo4j://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me-to-a-strong-password

# Where the bundled Neo4j publishes its ports on the host (Browser UI + Bolt).
# Defaults to 127.0.0.1. Override as needed.
# NEO4J_HOST_BIND=127.0.0.1
# NEO4J_HTTP_PORT=7474
# NEO4J_BOLT_PORT=7687

###########################
### LLM (cloud)
###########################

LLM_BINDING=openai
LLM_MODEL=gpt-4o
LLM_BINDING_API_KEY=sk-replace-with-your-openai-key
# Optional override of the API base URL (defaults to OpenAI's).
# LLM_BINDING_HOST=https://api.openai.com/v1

# Alternative providers — pick one or the other:
# LLM_BINDING=anthropic
# LLM_MODEL=claude-3-5-sonnet-20241022
# LLM_BINDING_API_KEY=sk-ant-...

###########################
### Embedding (cloud — OpenAI)
###########################

EMBEDDING_BINDING=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072
EMBEDDING_BINDING_API_KEY=sk-replace-with-your-openai-key

# IMPORTANT: changing the embedding model later requires wiping vector
# storage — the dimension is baked into pgvector columns. Pick before ingest.

###########################
### Reranker (cloud — Jina)
###########################

RERANK_BINDING=jina
RERANK_MODEL=jina-reranker-v2-base-multilingual
RERANK_BINDING_API_KEY=jina_replace-with-your-jina-key
# RERANK_BINDING_HOST=https://api.jina.ai/v1/rerank   # optional — Jina default

###########################
### Document parser (Docling)
###########################
#
# The bundled docling-serve container handles PDFs/Office docs with OCR.
# Without LIGHTRAG_PARSER set, the legacy text-only parser runs and scanned
# PDFs ingest as near-empty documents.
#
# Route file types to docling (left-to-right; suffix:engine, comma-separated):
LIGHTRAG_PARSER=pdf:docling,docx:docling,pptx:docling,xlsx:docling

DOCLING_ENDPOINT=http://docling:5001
# DOCLING_DO_OCR=true            # default true
# DOCLING_FORCE_OCR=true         # default true; re-OCRs even text-layer PDFs
# DOCLING_OCR_LANG=eng           # comma-separated; default = auto-detect
DOCLING_OCR_ENGINE=easyocr       # pinned: docling-serve v1.4.1 rejects 'auto'; pick easyocr/tesseract/rapidocr/tesserocr
# DOCLING_POLL_INTERVAL_SECONDS=2
# DOCLING_MAX_POLLS=180          # ~6 minutes total at default interval

# Where the bundled docling-serve publishes its port on the host. Defaults to
# 127.0.0.1:5001 — change only if you want host-side access for debugging.
# DOCLING_HOST_BIND=127.0.0.1
# DOCLING_HOST_PORT=5001

###########################
### Enterprise features (defaults: both ON)
###########################

# OAuth2 / Keycloak SSO. Set to false to use AUTH_ACCOUNTS or guest login.
# Full block: see env.example and docs/KEYCLOAK_SSO_SETUP.md.
OAUTH2_ENABLED=true
# OAUTH2_CLIENT_ID=lightrag
# OAUTH2_CLIENT_SECRET=your-keycloak-client-secret
# OAUTH2_ISSUER=https://id.example.org/realms/your-realm
# OAUTH2_AUTHORIZATION_ENDPOINT=...
# OAUTH2_TOKEN_ENDPOINT=...
# OAUTH2_USERINFO_ENDPOINT=...
# OAUTH2_JWKS_URI=...
# OAUTH2_REDIRECT_URI=http://your-host:9621/oauth2/callback
# OAUTH2_SCOPES=openid profile email

# Username/password fallback (use when OAUTH2_ENABLED=false).
# AUTH_ACCOUNTS=admin:replace-with-a-secure-password
# ADMIN_ACCOUNTS=admin

# Multi-tenancy — per-user isolated workspaces.
ENABLE_MULTI_TENANCY=true
